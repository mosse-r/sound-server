# Security defaults: localhost bind + mandatory shared token
SOUND_SERVER_HOST=127.0.0.1
SOUND_SERVER_PORT=8088
SOUND_SERVER_TOKEN=CHANGE_ME_STRONG_RANDOM_TOKEN

# Logging
SOUND_SERVER_LOG_LEVEL=INFO

# Playback backend: auto | mpv | ffplay | aplay
SOUND_SERVER_BACKEND=auto

# Optional output device
# mpv example (Pulse): pulse/bluez_output.XX_XX_XX_XX_XX_XX.a2dp-sink
# aplay example (ALSA): hw:0,0
SOUND_SERVER_AUDIO_DEVICE=

# Security hardening
SOUND_SERVER_ALLOW_NON_LOCAL=false
SOUND_SERVER_MAX_TEXT_LEN=500
